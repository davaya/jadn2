{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://oasis-open.org/openc2/jadn/v2.0/schema",
  "description": "Validates structure of a JADN schema, does not check values",
  "$ref": "#/$defs/Schema",
  "$defs": {
    "Schema": {
      "type": "object",
      "required": [
        "types"
      ],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "required": [
            "package"
          ],
          "additionalProperties": false,
          "properties": {
            "package": {
              "$ref": "#/$defs/Uri"
            },
            "version": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "comment": {
              "type": "string"
            },
            "copyright": {
              "type": "string"
            },
            "license": {
              "type": "string"
            },
            "namespaces": {
              "$ref": "#/$defs/Namespaces"
            },
            "roots": {
              "$ref": "#/$defs/Roots"
            },
            "config": {
              "$ref": "#/$defs/Config"
            },
            "jadn_version": {
              "type": "string"
            }
          }
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Type"
          }
        }
      }
    },
    "Namespaces": {
      "type": "array",
      "items": {"$ref": "#/$defs/PrefixNs"}
    },
    "PrefixNs": {
      "type": "array",
      "prefixItems": [
        {"$ref": "#/$defs/NSID"},
        {"$ref": "#/$defs/Uri"}
      ]
    },
    "Roots": {
      "type": "array",
      "items": {"$ref": "#/$defs/TypeName"}
    },
    "Config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$MaxBinary": {"type": "integer", "minValue": 1},
        "$MaxString": {"type": "integer", "minValue": 1},
        "$MaxElements": {"type": "integer", "minValue": 1},
        "$Sys": {"type": "string", "minLength": 1, "maxLength": 1},
        "$TypeName": {"type": "string", "minLength": 1, "maxLength": 127},
        "$FieldName": {"type": "string", "minLength": 1, "maxLength": 127},
        "$NSID": {"type": "string", "minLength": 1, "maxLength": 127}
      }
    },
    "Type": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "prefixItems": [
        {"$ref": "#/$defs/TypeName"},
        {"$ref": "#/$defs/CoreType"},
        {"$ref": "#/$defs/Options"},
        {"$ref": "#/$defs/Description"},
        {"$ref": "#/$defs/Fields"}
      ]
    },
    "Fields": {
      "type": "array",
      "items": {
        "anyOf": [
          {"$ref": "#/$defs/Item"},
          {"$ref": "#/$defs/Field"}
        ]
      }
    },
    "Item": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        {"type": "integer"},
        {"type": "string"},
        {"$ref": "#/$defs/Description"}
      ]
    },
    "Field": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "prefixItems": [
        {"type": "integer"},
        {"$ref": "#/$defs/FieldName"},
        {"$ref": "#/$defs/TypeRef"},
        {"$ref": "#/$defs/Options"},
        {"$ref": "#/$defs/Description"}
      ]
    },
    "NSID": {
      "type": "string"
    },
    "Uri": {
      "type": "string"
    },
    "TypeName": {
      "type": "string"
    },
    "TypeRef": {
      "type": "string"
    },
    "FieldName": {
      "type": "string"
    },
    "CoreType": {
      "type": "string",
      "enum": ["Binary", "Boolean", "Integer", "Number", "String",
               "Array", "ArrayOf", "Map", "MapOf", "Record",
               "Enumerated", "Choice"]
    },
    "Options": {
      "type": "array",
      "items": {"type": "string"}
    },
    "Description": {
      "type": "string"
    }
  }
}
