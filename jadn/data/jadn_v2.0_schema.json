{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://jadn-im.cc/schema/v2.0/jadn-structure",
  "description": "Validates well-formed structure of a JADN schema, does not check values",
  "$ref": "#/$defs/Schema",
  "$defs": {
    "Schema": {
      "type": "object",
      "required": [
        "types"
      ],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "$ref": "#/$defs/Metadata"
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Type"
          }
        }
      }
    },
    "Metadata": {
      "type": "object",
      "required": [
        "package"
      ],
      "properties": {
        "package": {"$ref": "#/$defs/Uri"},
        "prefixes": {"$ref": "#/$defs/Prefixes"},
        "roots": {"$ref": "#/$defs/Roots"},
        "jadn_version": {"$ref": "#/$defs/JADN-Version"},
        "version": {"$ref": "#/$defs/Version"},
        "config": {"$ref": "#/$defs/Config"},
        "desc": {"$ref": "#/$defs/Description"}
      },
      "additionalProperties": false
    },
    "Prefixes": {
      "type": "array",
      "items": {"$ref": "#/$defs/PxNs"}
    },
    "PxNs": {
      "type": "array",
      "prefixItems": [
        {"$ref": "#/$defs/Prefix"},
        {"$ref": "#/$defs/Uri"}
      ]
    },
    "Roots": {
      "type": "array",
      "items": {"$ref": "#/$defs/TypeName"}
    },
    "Config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "_maxBinary": {"type": "integer", "minimum": 1},
        "_maxString": {"type": "integer", "minimum": 1},
        "_maxElements": {"type": "integer", "minimum": 1},
        "_pathChar": {"type": "string", "minLength": 1, "maxLength": 1},
        "_typeNamePat": {"type": "string", "minLength": 1, "maxLength": 127},
        "_fieldNamePat": {"type": "string", "minLength": 1, "maxLength": 127},
        "_prefixPat": {"type": "string", "minLength": 1, "maxLength": 127}
      }
    },
    "Prefix": {"type": "string", "minLength": 1},
    "Uri": {"type": "string", "minLength": 1},
    "JADN-Version": {"type": "string", "minLength": 1},
    "Version": {"type": "string", "minLength": 1},
    "Type": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "prefixItems": [
        {"$ref": "#/$defs/TypeName"},
        {"$ref": "#/$defs/CoreType"},
        {"$ref": "#/$defs/Options"},
        {"$ref": "#/$defs/Description"},
        {"$ref": "#/$defs/Fields"}
      ]
    },
    "TypeName": {"type": "string", "minLength": 1},
    "CoreType": {
      "type": "string",
      "enum": ["Binary", "Boolean", "Integer", "Number", "String",
               "Array", "ArrayOf", "Map", "MapOf", "Record",
               "Enumerated", "Choice"]
    },
    "Options": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "Description": {
      "anyOf": [
        {"type": "string"},
        {"type": "object"}
      ]
    },
    "Fields": {
      "type": "array",
      "items": {
        "anyOf": [
          {"$ref": "#/$defs/Item"},
          {"$ref": "#/$defs/Field"}
        ]
      }
    },
    "Item": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        {"$ref": "#/$defs/ItemId"},
        {"$ref": "#/$defs/ItemValue"},
        {"$ref": "#/$defs/Description"}
      ]
    },
    "Field": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "prefixItems": [
        {"$ref": "#/$defs/FieldId"},
        {"$ref": "#/$defs/FieldName"},
        {"$ref": "#/$defs/TypeRef"},
        {"$ref": "#/$defs/Options"},
        {"$ref": "#/$defs/Description"}
      ]
    },
    "ItemId": {"type": "integer"},
    "ItemValue": {"type": "string"},
    "FieldId": {"type": "integer"},
    "FieldName": {"type": "string", "minLength": 1},
    "TypeRef": {"type": "string", "minLength": 1}
  }
}
